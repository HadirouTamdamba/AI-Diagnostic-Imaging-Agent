# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Application Configuration
MODEL_ID=gemini-flash-latest
MAX_IMAGE_SIZE=5242880
MAX_ANALYSIS_TIME=120
# Live web search for references. true = richer report (several API requests
# per analysis); false = 1 request/analysis to conserve free-tier quota.
ENABLE_WEB_SEARCH=true
# UI & report default language: en or fr (switchable in the UI)
DEFAULT_LANGUAGE=en

# Debug Configuration
DEBUG_MODE=false
LOG_LEVEL=INFO